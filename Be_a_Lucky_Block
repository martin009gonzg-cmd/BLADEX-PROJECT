-- Mapa de loops usando las nuevas funciones mejoradas
local LOOP_MAP = {
    AutoCollect = startCollectLoop,
    AutoUpgrades = startUpgradeLoop,
    AutoContainer = loopAutoContainer,
    AutoLBFarm = loopAutoLBFarm,
    AutoSell = loopAutoSell,
    AutoRebirth = loopAutoRebirth,
    AutoSpeed = startSpeedLoop,
    AutoPlaceBest = loopAutoPlaceBest,
}

local function toggle(name, val)
    _G[name] = val
    if val then
        -- Iniciar el loop correspondiente
        if name == "AutoCollect" then
            startCollectLoop()
        elseif name == "AutoUpgrades" then
            startUpgradeLoop()
        elseif name == "AutoSpeed" then
            startSpeedLoop()
        elseif LOOP_MAP[name] then
            -- Para loops simples
            setLoop(name, val, LOOP_MAP[name])
        end
    else
        -- Detener el loop correspondiente
        if name == "AutoCollect" then
            collectRunning = false
        elseif name == "AutoUpgrades" then
            if upgradeLoopThread then
                pcall(task.cancel, upgradeLoopThread)
                upgradeLoopThread = nil
            end
        elseif name == "AutoSpeed" then
            speedRunning = false
        else
            stopLoop(name)
        end
    end
end

-- Monitor de cambios para los loops que no son simples
task.spawn(function()
    local lastState = {}
    while true do
        for name, fn in pairs(LOOP_MAP) do
            local current = _G[name]
            if current ~= lastState[name] then
                if current then
                    if name == "AutoCollect" then
                        startCollectLoop()
                    elseif name == "AutoUpgrades" then
                        startUpgradeLoop()
                    elseif name == "AutoSpeed" then
                        startSpeedLoop()
                    else
                        startLoop(name, fn)
                    end
                else
                    if name == "AutoCollect" then
                        collectRunning = true
                    elseif name == "AutoUpgrades" then
                        if upgradeLoopThread then
                            pcall(task.cancel, upgradeLoopThread)
                            upgradeLoopThread = nil
                        end
                    elseif name == "AutoSpeed" then
                        speedRunning = false
                    else
                        stopLoop(name)
                    end
                end
                lastState[name] = current
            end
        end
        task.wait(0.5)
    end
end)

