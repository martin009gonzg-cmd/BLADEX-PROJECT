local function log(msg, level)
    if level == "error" then
        warn("[BLADEX] ❌ " .. msg)
    elseif level == "warn" then
        warn("[BLADEX] ⚠️ " .. msg)
    else
        print("[BLADEX] ✅ " .. msg)
    end
end

-- Invoke con reintentos y args variables
local function invokeWithRetry(remote, maxRetries, ...)
    if not remote then
        log("Remoto nil omitido", "warn")
        return false, nil
    end
    maxRetries = maxRetries or CFG.MAX_RETRIES
    local args = {...}
    for i = 1, maxRetries do
        local ok, res = pcall(function()
            return remote:InvokeServer(table.unpack(args))
        end)
        if ok then return true, res end
        log("Retry " .. i .. "/" .. maxRetries .. " → " .. tostring(remote.Name), "warn")
        task.wait(CFG.DELAYS.RETRY_WAIT)
    end
    return false, nil
end

-- Invoke seguro sin retorno importante
local function safeInvoke(remote, ...)
    if not remote then return false, "nil" end
    return pcall(remote.InvokeServer, remote, ...)
end

-- Verificar si el personaje está vivo
local function isAlive()
    local char = LP.Character
    if not char then return false end
    local hum = char:FindFirstChild("Humanoid")
    return hum and hum.Health > 0
end

-- Esperar personaje vivo
local function waitForCharacter()
    local char = LP.Character or LP.CharacterAdded:Wait()
    local hum  = char:WaitForChild("Humanoid", 10)
    if hum and hum.Health <= 0 then
        log("Esperando respawn...", "warn")
        char = LP.CharacterAdded:Wait()
        task.wait(CFG.DELAYS.RESPAWN_WAIT)
    end
    local hrp = char:WaitForChild("HumanoidRootPart", 10)
    return char, hrp
end

-- Verificar proximidad
local function isNear(cf, threshold)
    local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    return (hrp.Position - cf.Position).Magnitude < (threshold or 5)
end

-- Teleport con confirmación
local function teleportTo(cf, maxWait)
    maxWait = maxWait or 3
    local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    hrp.CFrame = cf
    task.wait(CFG.DELAYS.AFTER_TELEPORT)
    local t = tick()
    while tick() - t < maxWait do
        if (hrp.Position - cf.Position).Magnitude < 5 then return true end
        task.wait(0.1)
    end
    return false
end

