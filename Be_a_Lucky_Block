-- 6. NUEVO CICLO DE FARM LUCKY BLOCK (CON ESPERAS EXTRA)
-- ════════════════════════════════════════════════════════════════
_G.AutoZeus = _G.AutoZeus or false

local function log(msg, level)
    level = level or "info"
    if level == "error" then
        warn("[LB Farm] " .. msg)
    else
        print("[LB Farm] " .. msg)
    end
end

local function lbFarmCycle()
    log("Iniciando ciclo...")
    local _, hrp = waitForCharacter()
    if not hrp then return end

    -- 1. Base
    if not isNear(LB_CONFIG.COORDS.BASE, 5) then
        teleportToWithConfirm(LB_CONFIG.COORDS.BASE, 3)
    end

    -- 2. Caminadora
    if not isNear(LB_CONFIG.COORDS.CAMINADORA, 5) then
        teleportToWithConfirm(LB_CONFIG.COORDS.CAMINADORA, 3)
    end

    -- 3. StartRun → runId
    local okStart, runId = invokeWithRetry(StartRun, LB_CONFIG.MAX_RETRIES)
    if not okStart then
        log("Falló StartRun", "error")
        return
    end
    log("StartRun OK, runId: " .. tostring(runId))

    -- 4. StartMove
    if not invokeWithRetry(StartMove, LB_CONFIG.MAX_RETRIES) then
        log("Falló StartMove", "error")
        return
    end

    -- 5. OpenLuckyBlock (parámetro según toggle)
    local blockType = _G.AutoZeus and "ZEUS" or "base14"
    if not invokeWithRetry(OpenLuckyBlock, LB_CONFIG.MAX_RETRIES, blockType) then
        log("Falló OpenLuckyBlock con tipo " .. blockType, "error")
        return
    end
    log("OpenLuckyBlock OK (" .. blockType .. ")")

    -- 6. UpdateCFrame
    if not invokeWithRetry(UpdateCFrame, LB_CONFIG.MAX_RETRIES, hrp.CFrame) then
        log("Falló UpdateCFrame", "error")
        return
    end

    -- Espera extra para que la carrera termine en el servidor
    task.wait(0.8)

    -- 7. Regresar a base
    if not isNear(LB_CONFIG.COORDS.BASE, 5) then
        teleportToWithConfirm(LB_CONFIG.COORDS.BASE, 3)
    end

    -- Espera final antes de repetir (evita solapamiento)
    task.wait(LB_CONFIG.DELAYS.CYCLE_END)
    log("Ciclo completado")
end

local lbRunning = false
local function startLbFarmLoop()
    if lbRunning then return end
    lbRunning = true
    task.spawn(function()
        while _G.AutoLBFarm do
            local ok, err = pcall(lbFarmCycle)
            if not ok then
                warn("[LB Farm] Error: " .. tostring(err))
                task.wait(2)
            end
        end
        lbRunning = false
    end)
end

