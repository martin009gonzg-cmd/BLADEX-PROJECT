-- Auto Farm Best Brainrots
local autoFarm = false
BrainrotsSection:AddToggle({
    Name = "Auto Farm Best Brainrots",
    Default = false,
    Callback = function(state)
        autoFarm = state
        if state then
            task.spawn(function()
                while autoFarm do
                    local player = game.Players.LocalPlayer
                    local char = player.Character or player.CharacterAdded:Wait()
                    local root = char:WaitForChild("HumanoidRootPart")
                    local humanoid = char:WaitForChild("Humanoid")
                    local userId = player.UserId
                    local modelsFolder = workspace:WaitForChild("RunningModels")
                    local target = workspace:WaitForChild("CollectZones"):WaitForChild("base14")

                    root.CFrame = CFrame.new(715, 39, -2122)
                    task.wait(0.3)
                    humanoid:MoveTo(Vector3.new(710, 39, -2122))

                    local ownedModel = nil
                    repeat
                        task.wait(0.3)
                        for _, obj in ipairs(modelsFolder:GetChildren()) do
                            if obj:IsA("Model") and obj:GetAttribute("OwnerId") == userId then
                                ownedModel = obj
                                break
                            end
                        end
                    until ownedModel ~= nil or not autoFarm
                    if not autoFarm then break end

                    if ownedModel.PrimaryPart then ownedModel:SetPrimaryPartCFrame(target.CFrame)
                    else local p = ownedModel:FindFirstChildWhichIsA("BasePart"); if p then p.CFrame = target.CFrame end end
                    task.wait(0.7)

                    if ownedModel and ownedModel.Parent == modelsFolder then
                        if ownedModel.PrimaryPart then ownedModel:SetPrimaryPartCFrame(target.CFrame * CFrame.new(0, -5, 0))
                        else local p = ownedModel:FindFirstChildWhichIsA("BasePart"); if p then p.CFrame = target.CFrame * CFrame.new(0, -5, 0) end end
                    end

                    repeat
                        task.wait(0.3)
                    until not autoFarm or (ownedModel == nil or ownedModel.Parent ~= modelsFolder)
                    if not autoFarm then break end

                    local oldChar = player.Character
                    repeat
                        task.wait(0.2)
                    until not autoFarm or (player.Character ~= oldChar and player.Character ~= nil)
                    if not autoFarm then break end

                    task.wait(0.4)
                    local newChar = player.Character
                    local newRoot = newChar:WaitForChild("HumanoidRootPart")
                    newRoot.CFrame = CFrame.new(737, 39, -2118)
                    task.wait(2.1)
                end
            end)
        end
    end
})

-- ======================= STATS =======================
local StatsSection = StatsTab:DrawSection({ Name = "Lucky Block Speed", Position = "left" })

local player = game.Players.LocalPlayer
local runningSpeed = false
local sliderValue = 1000
local originalSpeed = nil
local currentModel = nil

local function getMyModel()
    local folder = workspace:FindFirstChild("RunningModels")
    if not folder then return nil end
    for _, model in ipairs(folder:GetChildren()) do
        if model:GetAttribute("OwnerId") == player.UserId then return model end
    end
    return nil
end

local function applySpeed()
    local model = getMyModel()
    if not model then currentModel = nil; return end
    if model ~= currentModel then
        currentModel = model
        originalSpeed = model:GetAttribute("MovementSpeed")
    end
    if runningSpeed then
        if originalSpeed == nil then originalSpeed = model:GetAttribute("MovementSpeed") end
        model:SetAttribute("MovementSpeed", sliderValue)
    end
end

task.spawn(function()
    while true do
        if runningSpeed then applySpeed() end
        task.wait(0.2)
    end
end)

StatsSection:AddToggle({
    Name = "Enable Custom Lucky Block Speed",
    Default = false,
    Callback = function(state)
        runningSpeed = state
        if not runningSpeed then
            local model = getMyModel()
            if model and originalSpeed ~= nil then model:SetAttribute("MovementSpeed", originalSpeed) end
            originalSpeed = nil
            currentModel = nil
        end
    end
})
StatsSection:AddSlider({
    Name = "Lucky Block Speed",
    Min = 50, Max = 3000, Default = 1000, Round = 0,
    Callback = function(v) sliderValue = v end
})

