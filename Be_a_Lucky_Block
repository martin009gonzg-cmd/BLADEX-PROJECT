local cashPhysicalRunning = false
local cashPhysicalThread = nil

local function isCashPart(part)
    if not part:IsA("BasePart") then return false end
    if part.Transparency >= 0.8 then return false end
    
    local name = part.Name:lower()
    
    if name:find("cash") or name:find("money") or name:find("coin") or 
       name:find("dinero") or name:find("dolar") or name:find("$") then
        return true
    end
    
    if part:FindFirstChildOfClass("BillboardGui") or 
       part:FindFirstChildOfClass("SurfaceGui") then
        return true
    end
    
    if part.Color and (part.Color.r > 0.5 and part.Color.g > 0.5 and part.Color.b < 0.3) then
        return true
    end
    
    return false
end

