-- 6. CICLO DE FARM LUCKY BLOCK (mejorado)
-- ════════════════════════════════════════════════════════════════
_G.AutoZeus = _G.AutoZeus or false

-- Logger con niveles: info / warn / error
local function log(msg, level)
    level = level or "info"
    local prefix = "[LB Farm] "
    if level == "error" then
        warn(prefix .. "❌ " .. msg)
    elseif level == "warn" then
        warn(prefix .. "⚠️ " .. msg)
    else
        print(prefix .. "✅ " .. msg)
    end
end

local function lbFarmCycle()
    log("Iniciando ciclo...")

    -- Esperar personaje vivo
    local char, hrp = waitForCharacter()
    if not hrp then
        log("No se encontró HumanoidRootPart", "error")
        return false
    end

    -- 1. Ir a Base (si no está cerca)
    if not isNear(LB_CONFIG.COORDS.BASE, 5) then
        if not teleportToWithConfirm(LB_CONFIG.COORDS.BASE, 3) then
            log("No se pudo llegar a BASE", "warn")
        end
    end

    -- 2. Ir a Caminadora
    if not teleportToWithConfirm(LB_CONFIG.COORDS.CAMINADORA, 3) then
        log("No se pudo llegar a CAMINADORA", "error")
        return false
    end

    -- 3. StartRun → obtener runId
    local okStart, runId = invokeWithRetry(StartRun, LB_CONFIG.MAX_RETRIES)
    if not okStart then
        log("Falló StartRun", "error")
        return false
    end
    log("StartRun OK | runId=" .. tostring(runId))
    task.wait(LB_CONFIG.DELAYS.BETWEEN_STEPS)

    -- 4. StartMove (pasar runId si el servidor lo requiere)
    local okMove, _ = invokeWithRetry(StartMove, LB_CONFIG.MAX_RETRIES, runId)
    if not okMove then
        log("Falló StartMove", "error")
        return false
    end
    log("StartMove OK")
    task.wait(LB_CONFIG.DELAYS.BETWEEN_STEPS)

    -- 5. OpenLuckyBlock (bloque según toggle Zeus, pasando runId)
    local blockType = _G.AutoZeus and "ZEUS" or (_G.CustomBlockType or "base14")
    local okBlock, _ = invokeWithRetry(OpenLuckyBlock, LB_CONFIG.MAX_RETRIES, blockType, runId)
    if not okBlock then
        log("Falló OpenLuckyBlock (" .. blockType .. ")", "error")
        return false
    end
    log("OpenLuckyBlock OK | tipo=" .. blockType)
    task.wait(LB_CONFIG.DELAYS.AFTER_OPEN_BLOCK)

    -- 6. UpdateCFrame (pasando runId para que el servidor valide la carrera)
    -- Actualizar hrp por si cambió (ej. respawn)
    hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then
        log("HRP perdido antes de UpdateCFrame", "error")
        return false
    end
    local okCF, _ = invokeWithRetry(UpdateCFrame, LB_CONFIG.MAX_RETRIES, hrp.CFrame, runId)
    if not okCF then
        log("Falló UpdateCFrame", "error")
        return false
    end
    log("UpdateCFrame OK")

    -- 7. Espera dinámica: da tiempo al servidor para terminar la carrera
    --    En vez de esperar fijo 0.8s, esperamos hasta CYCLE_END con check activo
    local waitStart = tick()
    while _G.AutoLBFarm and tick() - waitStart < LB_CONFIG.DELAYS.RUN_FINISH_MAX do
        task.wait(0.2)
    end

    -- 8. Regresar a base
    if not isNear(LB_CONFIG.COORDS.BASE, 5) then
        teleportToWithConfirm(LB_CONFIG.COORDS.BASE, 3)
    end

    task.wait(LB_CONFIG.DELAYS.CYCLE_END)
    log("Ciclo completado ✔")
    return true
end

-- ════════════════════════════════════════════════════════════════
-- LOOP PRINCIPAL (fix: lbRunning se resetea correctamente)
-- ════════════════════════════════════════════════════════════════
local lbRunning = false
local lbCycleCount = 0
local lbFailCount  = 0

local function startLbFarmLoop()
    if lbRunning then return end
    lbRunning = true
    lbCycleCount = 0
    lbFailCount  = 0

    task.spawn(function()
        while _G.AutoLBFarm do
            local ok, err = pcall(lbFarmCycle)
            if ok then
                lbCycleCount += 1
                lbFailCount   = 0  -- reset de fallos consecutivos
                log("Ciclos completados: " .. lbCycleCount)
            else
                lbFailCount += 1
                warn("[LB Farm] Error en ciclo #" .. lbCycleCount .. ": " .. tostring(err))
                -- Si falla 5 veces seguidas, pausar más tiempo
                local pauseTime = lbFailCount >= 5 and 10 or 2
                if lbFailCount >= 5 then
                    warn("[LB Farm] ⚠️ 5 fallos seguidos, pausando " .. pauseTime .. "s...")
                end
                task.wait(pauseTime)
            end
        end
        lbRunning = false
        log("Loop detenido")
    end)
end

