-- Upgrade Brainrots mejorado (ráfagas paralelas)
local upgradeLoopThread = nil
local function startUpgradeLoop()
    if upgradeLoopThread then return end
    upgradeLoopThread = task.spawn(function()
        while _G.AutoUpgrades do
            -- Disparamos peticiones para los 30 slots casi al mismo tiempo
            for i = 30, 1, -1 do
                if not _G.AutoUpgrades then break end
                
                -- Usamos task.spawn para que no espere respuesta del servidor entre cada slot
                task.spawn(function()
                    if rf.Brainrot then
                        pcall(function() 
                            rf.Brainrot:InvokeServer(tostring(i)) 
                        end)
                    end
                end)
                
                -- Pequeñísimo delay cada 5 slots para estabilidad de red
                if i % 5 == 0 then task.wait(0.01) end 
            end
            
            -- Espera entre ráfagas completas de los 30 slots
            task.wait(0.4) 
        end
        upgradeLoopThread = nil
    end)
end

