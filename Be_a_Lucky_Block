-- 3. CONFIGURACIÓN LUCKY BLOCK (COORDENADAS Y DELAYS AJUSTADOS)
-- ════════════════════════════════════════════════════════════════
local LB_CONFIG = {
    DELAYS = {
        AFTER_TELEPORT   = 0.3,
        AFTER_ACTION     = 0.2,
        AFTER_OPEN_BLOCK = 0.2,
        BETWEEN_STEPS    = 0.1,
        CYCLE_END        = 1.5,   -- aumentado para evitar "already running"
        RESPAWN_WAIT     = 3.0,
    },
    COORDS = {
        CAMINADORA = CFrame.new(588.96, 38.18, -2127.26),
        BASE       = CFrame.new(733.21, 37.51, -2153.56),
    },
    MAX_RETRIES = 2,
}

