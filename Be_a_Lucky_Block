local function getCollectZone(baseName)
    local collectZones = workspace:FindFirstChild("CollectZones")
    if not collectZones then return nil end
    return collectZones:FindFirstChild(baseName)
end

local function brainrotFarmCycle()
    local baseName = _G.AutoZeus and "ZEUS" or (_G.SelectedBase or "base14")
    local targetZone = getCollectZone(baseName)
    if not targetZone then
        warn("[BrainrotFarm] No se encontró CollectZones/" .. baseName)
        return false, "Zona no encontrada"
    end

    local player = LP
    local userId = player.UserId
    local modelsFolder = workspace:FindFirstChild("RunningModels")
    if not modelsFolder then
        warn("[BrainrotFarm] No se encontró RunningModels")
        return false, "RunningModels no existe"
    end

    -- 1. Asegurar personaje y teletransportar a la zona de recolección
    local char, hrp = waitForCharacter()
    if not hrp then return false, "Sin personaje" end
    local arrivalPos = targetZone.CFrame * CFrame.new(0, 0, -5)
    teleportToWithConfirm(arrivalPos, 3)
    task.wait(0.5)

    -- 2. Buscar el brainrot propio con timeout
    local ownedModel = nil
    local startTime = tick()
    local timeout = 10
    repeat
        task.wait(0.3)
        for _, obj in ipairs(modelsFolder:GetChildren()) do
            if obj:IsA("Model") and obj:GetAttribute("OwnerId") == userId then
                ownedModel = obj
                break
            end
        end
        if tick() - startTime > timeout then
            warn("[BrainrotFarm] No se encontró brainrot propio después de " .. timeout .. "s")
            return false, "Sin brainrot"
        end
    until ownedModel or not _G.AutoLBFarm

    if not _G.AutoLBFarm then return false, "Desactivado" end

    -- 3. Mover el modelo a la zona de recolección
    local success = false
    if ownedModel.PrimaryPart then
        ownedModel:SetPrimaryPartCFrame(targetZone.CFrame)
        success = true
    else
        local part = ownedModel:FindFirstChildWhichIsA("BasePart")
        if part then
            part.CFrame = targetZone.CFrame
            success = true
        end
    end
    if not success then
        warn("[BrainrotFarm] No se pudo mover el modelo")
        return false, "Modelo inválido"
    end
    task.wait(0.5)

    -- 4. Hundir el modelo para activar recolección
    if ownedModel.PrimaryPart then
        ownedModel:SetPrimaryPartCFrame(targetZone.CFrame * CFrame.new(0, -5, 0))
    else
        local part = ownedModel:FindFirstChildWhichIsA("BasePart")
        if part then part.CFrame = targetZone.CFrame * CFrame.new(0, -5, 0) end
    end

    -- 5. Esperar a que desaparezca (timeout)
    local waitStart = tick()
    local waitTimeout = 8
    repeat
        task.wait(0.2)
        if not modelsFolder:FindFirstChild(ownedModel.Name) then break end
        if tick() - waitStart > waitTimeout then
            warn("[BrainrotFarm] El modelo no desapareció, continuando")
            break
        end
    until not _G.AutoLBFarm

    -- 6. Esperar a que el jugador reaparezca (si murió)
    local oldChar = player.Character
    local respawnTimeout = tick() + 5
    while player.Character == oldChar and tick() < respawnTimeout and _G.AutoLBFarm do
        task.wait(0.2)
    end

    task.wait(1.5)
    return true
end

local function loopAutoLBFarm()
    while _G.AutoLBFarm do
        local ok, err = pcall(brainrotFarmCycle)
        if not ok then
            warn("[BrainrotFarm] Error en ciclo: " .. tostring(err))
            task.wait(2)
        end
    end
end
