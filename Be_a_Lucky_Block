-- Función para obtener el modelo del jugador actual (RunningModels)
local function getMyModel()
    local folder = workspace:FindFirstChild("RunningModels")
    if not folder then return nil end
    for _, model in ipairs(folder:GetChildren()) do
        if model:GetAttribute("OwnerId") == player.UserId then
            return model
        end
    end
    return nil
end

-- Función para aplicar la velocidad al modelo
local function applySpeed()
    local model = getMyModel()
    if not model then
        currentModel = nil
        return
    end
    if model ~= currentModel then
        currentModel = model
        originalSpeed = model:GetAttribute("MovementSpeed")
    end
    if runningSpeed then
        model:SetAttribute("MovementSpeed", sliderValue)
    end
end

-- Bucle de actualización de velocidad (se ejecuta constantemente)
task.spawn(function()
    while true do
        if runningSpeed then
            applySpeed()
        end
        task.wait(0.2)
    end
end)

-- Función para parsear texto de dinero (ej. "1.2K" -> 1200)
local suffix = { K = 1e3, M = 1e6, B = 1e9, T = 1e12, Qa = 1e15, Qi = 1e18, Sx = 1e21, Sp = 1e24, Oc = 1e27, No = 1e30, Dc = 1e33 }
local function parseCash(text)
    text = text:gsub("%$", ""):gsub(",", ""):gsub("%s+", "")
    local num = tonumber(text:match("[%d%.]+"))
    local suf = text:match("%a+")
    if not num then return 0 end
    if suf and suffix[suf] then
        return num * suffix[suf]
    end
    return num
end

-- Función para mostrar un diálogo con dos botones usando Compkiller
local function showDialog(title, content, confirmCallback, cancelCallback)
    -- Crear una ventana temporal
    local dialogWindow = Compkiller.new({
        Name = title,
        Keybind = "None",  -- sin keybind
        Logo = Compkiller.Logo,
        Scale = UDim2.new(0, 300, 0, 150)
    })
    dialogWindow:SetVisible(true) -- asegurar que se muestre

    -- Crear una pestaña única
    local tab = dialogWindow:DrawTab({ Name = "Dialog", Icon = "info", Type = "Single" })
    local section = tab:DrawSection({ Name = "" })

    -- Agregar el contenido como un párrafo (usando AddParagraph)
    local para = section:AddParagraph({ Title = title, Content = content })

    -- Agregar dos botones: Confirmar y Cancelar
    local confirmBtn = section:AddButton({ Name = "Confirm", Callback = function()
        if confirmCallback then confirmCallback() end
        dialogWindow:SetVisible(false)
        dialogWindow.Root:Destroy()
    end })

    local cancelBtn = section:AddButton({ Name = "Cancel", Callback = function()
        if cancelCallback then cancelCallback() end
        dialogWindow:SetVisible(false)
        dialogWindow.Root:Destroy()
    end })

    -- Ajustar tamaño de la ventana
    task.wait(0.1)
    dialogWindow:SetVisible(true)
end

