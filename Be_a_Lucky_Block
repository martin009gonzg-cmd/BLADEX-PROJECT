rewardSection:AddButton({ Name="Buy Best Luckyblock", Callback=function()
    local buy = findRemote("SkinService", "BuySkin")
    if not buy then notify("⚠ Remoto BuySkin no encontrado.", 5) return end
    local gui = LP.PlayerGui:FindFirstChild("Windows")
    local scrollingFrame = gui and gui:FindFirstChild("PickaxeShop") and
        gui.PickaxeShop:FindFirstChild("ShopContainer") and
        gui.PickaxeShop.ShopContainer:FindFirstChild("ScrollingFrame")
    if not scrollingFrame then notify("⚠ ScrollingFrame no encontrado.", 5) return end
    local cash = LP.leaderstats.Cash.Value
    local bestSkin, bestPrice = nil, 0
    for _, name in ipairs(skins) do
        local item = scrollingFrame:FindFirstChild(name)
        if item then
            local buyButton = item:FindFirstChild("Main") and item.Main:FindFirstChild("Buy") and item.Main.Buy:FindFirstChild("BuyButton")
            if buyButton and buyButton.Visible then
                local cashLabel = buyButton:FindFirstChild("Cash")
                if cashLabel then
                    local price = parseCash(cashLabel.Text)
                    if cash >= price and price > bestPrice then bestSkin = name bestPrice = price end
                end
            end
        end
    end
    if bestSkin then pcall(function() buy:InvokeServer(bestSkin) end) notify("Comprado: " .. bestSkin, 4)
    else notify("No hay skin disponible.", 4) end
end })

rewardSection:AddButton({ Name="Claim Event Pass Rewards", Callback=function()
    local claim = findRemote("SeasonPassService", "ClaimPassReward")
    if not claim then notify("⚠ Remoto ClaimPassReward no encontrado.", 5) return end
    local ok, gui = pcall(function()
        return LP:WaitForChild("PlayerGui"):WaitForChild("Windows")
            :WaitForChild("Event"):WaitForChild("Frame"):WaitForChild("Frame")
            :WaitForChild("Windows"):WaitForChild("Pass"):WaitForChild("Main"):WaitForChild("ScrollingFrame")
    end)
    if not ok or not gui then notify("⚠ GUI de evento no encontrada.", 5) return end
    local claimed = 0
    for i = 1, 10 do
        local item = gui:FindFirstChild(tostring(i))
        if item and item:FindFirstChild("Frame") and item.Frame:FindFirstChild("Free") then
            local free = item.Frame.Free
            local locked = free:FindFirstChild("Locked")
            local claimedEl = free:FindFirstChild("Claimed")
            if locked and not locked.Visible and not (claimedEl and claimedEl.Visible) then
                pcall(function() claim:InvokeServer("Free", i) end)
                claimed = claimed + 1
                task.wait(0.1)
            end
        end
    end
    notify("Recompensas reclamadas: " .. claimed, 4)
end })

