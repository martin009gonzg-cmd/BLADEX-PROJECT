-- 6. CICLO MEJORADO DE LUCKY BLOCK (con selector de base)
-- ════════════════════════════════════════════════════════════════
_G.LBType = _G.LBType or "base14"

local inRun = false

local function lbFarmCycle()
    if inRun then
        log("Ya hay una carrera en curso, esperando...")
        return
    end
    inRun = true

    local success, err = pcall(function()
        local blockType = _G.LBType
        local coords = LB_COORDS[blockType]
        if not coords then
            error("Coordenadas no definidas para: " .. tostring(blockType))
        end

        local char, hrp = waitForStableCharacter()
        if not hrp then error("Personaje no listo") end

        if not teleportToWithConfirm(coords.BASE, 4, 12) then
            error("No se pudo llegar a base")
        end

        if not ensureAtTreadmill(coords) then
            error("No se pudo llegar a la caminadora")
        end

        local ok, runId = invokeWithBackoff(StartRun, 3)
        if not ok then error("StartRun falló") end
        log("StartRun OK, runId: " .. tostring(runId))

        if not invokeWithBackoff(StartMove, 3) then
            error("StartMove falló")
        end

        if not invokeWithBackoff(OpenLuckyBlock, 3, blockType) then
            error("OpenLuckyBlock falló con tipo " .. blockType)
        end
        log("OpenLuckyBlock OK (" .. blockType .. ")")

        if not invokeWithBackoff(UpdateCFrame, 3, hrp.CFrame) then
            error("UpdateCFrame falló")
        end

        task.wait(1.2)

        teleportToWithConfirm(coords.BASE, 3, 12)
        task.wait(LB_CONFIG.DELAYS.CYCLE_END)
    end)

    if not success then
        warn("[LB Farm] Error en ciclo: " .. tostring(err))
        task.wait(2)
    end

    inRun = false
end

local lbRunning = false
local function startLbFarmLoop()
    if lbRunning then return end
    lbRunning = true
    task.spawn(function()
        while _G.AutoLBFarm do
            local ok, err = pcall(lbFarmCycle)
            if not ok then
                warn("[LB Farm] Error en el bucle: " .. tostring(err))
                task.wait(2)
            end
        end
        lbRunning = false
    end)
end

