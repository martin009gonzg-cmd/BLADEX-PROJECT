}

-- ════════════════════════════════════════════════════════════════
-- 2. REMOTOS LUCKY BLOCK
-- ════════════════════════════════════════════════════════════════
local lbRF = ReplicatedStorage.Packages._Index
    :FindFirstChild("sleitnick_knit@1.7.0")
    .knit.Services.RunningService.RF

local StartRun       = lbRF:WaitForChild("StartRun",       10)
local EndMove        = lbRF:WaitForChild("EndMove",        10)
local OpenLuckyBlock = lbRF:WaitForChild("OpenLuckyBlock", 10)
local Collected      = lbRF:WaitForChild("Collected",      10)
local UpdateCFrame   = lbRF:WaitForChild("UpdateCFrame",   10)

-- ════════════════════════════════════════════════════════════════
-- 3. CONFIGURACIÓN LUCKY BLOCK
-- ════════════════════════════════════════════════════════════════
local LB_CONFIG = {
    DELAYS = {
        AFTER_TELEPORT   = 0.8,
        AFTER_ACTION     = 0.6,
        AFTER_OPEN_BLOCK = 0.9,
        BETWEEN_STEPS    = 0.5,
        CYCLE_END        = 1.0,
        RESPAWN_WAIT     = 3.0,
    },
    COORDS = {
        CAMINADORA = CFrame.new(710.440674,  38.81287,   -2124.65723),
        BASE       = CFrame.new(730.310547,  38.8128662, -2152.41089),
    },
    MAX_RETRIES = 3,
}

-- ════════════════════════════════════════════════════════════════
-- 4. FUNCIONES AUXILIARES
-- ════════════════════════════════════════════════════════════════
local function safeInvoke(remote, ...)
    local ok, res = pcall(remote.InvokeServer, remote, ...)
    return ok and res or nil
end

local function teleportTo(cf, label)
    for _ = 1, LB_CONFIG.MAX_RETRIES do
        local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            hrp.CFrame = cf
            task.wait(LB_CONFIG.DELAYS.AFTER_TELEPORT)
            if (hrp.CFrame.Position - cf.Position).Magnitude < 5 then return true end
        end
        task.wait(0.5)
    end
    return false
end

local function getLuckyBlockId()
    local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return "10708364552" end
    local closest, closestDist = nil, math.huge
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj.Name:lower():find("lucky", 1, true) then
            local pos
            if obj:IsA("Model") then
                local ok, p = pcall(function() return obj:GetPivot().Position end)
                pos = ok and p
            elseif obj:IsA("BasePart") then
                pos = obj.Position
            end
            if pos then
                local dist = (hrp.Position - pos).Magnitude
                if dist < closestDist then
                    closestDist = dist
                    closest = obj
                end
            end
        end
    end
    if closest then
        return tostring(
            closest:GetAttribute("Id") or
            closest:GetAttribute("ID") or
            closest:GetAttribute("BlockId") or
            closest.Name
        )
    end
    return "10708364552"
end

local function waitForCharacter()
    local char = LP.Character or LP.CharacterAdded:Wait()
    local hum  = char:WaitForChild("Humanoid", 10)
    if hum and hum.Health <= 0 then
        char = LP.CharacterAdded:Wait()
        task.wait(LB_CONFIG.DELAYS.RESPAWN_WAIT)
    end
    return char, char:WaitForChild("HumanoidRootPart")
end

-- ════════════════════════════════════════════════════════════════
-- 5. LOOPS DE AUTOMATIZACIÓN
-- ════════════════════════════════════════════════════════════════

-- 5.1 Auto dinero (firetouchinterest)
local collectRunning = false
local function startCollectLoop()
    if collectRunning then return end
    collectRunning = true
    task.spawn(function()
        _G.AutoCashPhysical = true
        while _G.AutoCollect do
            for _, v in pairs(workspace:GetDescendants()) do
                if not _G.AutoCollect then break end
                if v:IsA("BasePart") and v.Transparency < 1 then
                    if v:FindFirstChildOfClass("BillboardGui") or v:FindFirstChildOfClass("SurfaceGui") then
                        local char = LP.Character
                        if char and char:FindFirstChild("HumanoidRootPart") then
                            firetouchinterest(char.HumanoidRootPart, v, 0)
                            task.wait()
                            firetouchinterest(char.HumanoidRootPart, v, 1)
                        end
                    end
                end
            end
            task.wait(0.1)
        end
        _G.AutoCashPhysical = false
        collectRunning = false
    end)
end

-- 5.2 Auto mejora brainrots (30 -> 1)
local upgradeRunning = false
local function startUpgradeLoop()
    if upgradeRunning then return end
    upgradeRunning = true
    task.spawn(function()
        while _G.AutoUpgrades do
            for i = 30, 1, -1 do
                if not _G.AutoUpgrades then break end
                safeInvoke(rf.Brainrot, tostring(i))
                task.wait(0.05)
            end
            task.wait(0.5)
        end
        upgradeRunning = false
    end)
end

