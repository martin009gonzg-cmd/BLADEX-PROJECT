-- Mapa de loops
local LOOP_MAP = {
    AutoCollect = startCollectLoop,
    AutoContainer = loopAutoContainer,
    AutoLBFarm = loopAutoLBFarm,
    AutoSell = loopAutoSell,
    AutoRebirth = loopAutoRebirth,
    AutoSpeed = startSpeedLoop,
    AutoPlaceBest = loopAutoPlaceBest,
}

-- Funcion toggle principal
local function toggle(name, val)
    _G[name] = val
    if val then
        if name == "AutoCollect" then
            startCollectLoop()
        elseif name == "AutoSpeed" then
            startSpeedLoop()
        elseif name == "AutoUpgrades" then
            startMegaUpgrade()
        elseif name == "MegaUpgrade" then
            startMegaUpgrade()
        elseif name == "AutoCashPhysical" then
            startCashPhysical()
        elseif name == "HideUI" then
            if val then
                initUIHider()
            end
        elseif LOOP_MAP[name] then
            startLoop(name, LOOP_MAP[name])
        end
    else
        if name == "AutoCollect" then
            collectRunning = false
        elseif name == "AutoSpeed" then
            speedRunning = false
        elseif name == "AutoUpgrades" or name == "MegaUpgrade" then
            stopMegaUpgrade()
        elseif name == "AutoCashPhysical" then
            stopCashPhysical()
        else
            stopLoop(name)
        end
    end
end

-- Monitor de cambios
task.spawn(function()
    local lastState = {}
    while true do
        for name, fn in pairs(LOOP_MAP) do
            local current = _G[name]
            if current ~= lastState[name] then
                if current then
                    if name == "AutoCollect" then
                        startCollectLoop()
                    elseif name == "AutoSpeed" then
                        startSpeedLoop()
                    else
                        startLoop(name, fn)
                    end
                else
                    if name == "AutoCollect" then
                        collectRunning = false
                    elseif name == "AutoSpeed" then
                        speedRunning = false
                    else
                        stopLoop(name)
                    end
                end
                lastState[name] = current
            end
        end
        
        if (_G.AutoUpgrades or _G.MegaUpgrade) and not upgradeRunning then
            startMegaUpgrade()
        elseif not (_G.AutoUpgrades or _G.MegaUpgrade) and upgradeRunning then
            stopMegaUpgrade()
        end
        
        if _G.AutoCashPhysical and not cashPhysicalRunning then
            startCashPhysical()
        elseif not _G.AutoCashPhysical and cashPhysicalRunning then
            stopCashPhysical()
        end
        
        task.wait(0.5)
    end
end)

