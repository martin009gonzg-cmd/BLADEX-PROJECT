local function toggle(name, val)
    _G[name] = val
    if val then
        if name == "AutoUpgrades" then startUpgradeLoop()
        elseif name == "AutoSpeed" then startSpeedLoop()
        elseif LOOP_MAP[name] then startLoop(name, LOOP_MAP[name]) end
    else
        if name == "AutoUpgrades" then
            if upgradeLoopThread then pcall(task.cancel, upgradeLoopThread) upgradeLoopThread = nil end
        elseif name == "AutoSpeed" then
            speedRunning = false
        else
            stopLoop(name)
        end
    end
end

