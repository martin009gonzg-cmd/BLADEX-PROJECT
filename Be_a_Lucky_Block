local LB_CONFIG = {
    DELAYS = {
        AFTER_TELEPORT   = 0.3,
        AFTER_ACTION     = 0.2,
        AFTER_OPEN_BLOCK = 0.2,
        BETWEEN_STEPS    = 0.1,
        CYCLE_END        = 1.5,
        RESPAWN_WAIT     = 3.0,
        RUN_FINISH_MAX   = 4.0,   -- máximo a esperar que el servidor confirme fin de carrera
    },
    COORDS = {
        CAMINADORA = CFrame.new(588.96, 38.18, -2127.26),
        BASE       = CFrame.new(733.21, 37.51, -2153.56),
    },
    MAX_RETRIES  = 3,
    RETRY_DELAY  = 0.5,
}

