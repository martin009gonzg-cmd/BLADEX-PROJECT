-- 8. LOOP MANAGER
-- ════════════════════════════════════════════════════════════════
local lbRunning = false

local function startLbFarmLoop()
    if lbRunning then return end
    lbRunning = true
    task.spawn(function()
        while _G.AutoLBFarm do
            local ok, err = pcall(lbFarmCycle)
            if not ok then
                warn("[BLADEX] Error: " .. tostring(err))
                task.wait(2)
            end
        end
        lbRunning = false
        log("Farm detenido")
    end)
end

