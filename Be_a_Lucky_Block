local skinRunning = false
local function startSkinLoop()
    if skinRunning then return end
    skinRunning = true
    task.spawn(function()
        while _G.AutoSkins do
            for _, skinId in ipairs(SKIN_LIST) do
                if not _G.AutoSkins then break end
                safeInvoke(rf.Skin, skinId)
                task.wait(3)
            end
        end
        skinRunning = false
    end)
