-- 7. CICLO DE FARM LUCKY BLOCK
-- ════════════════════════════════════════════════════════════════
local function lbFarmCycle()
    if not isAlive() then
        log("Personaje no disponible, esperando...", "warn")
        waitForCharacter()
        return
    end

    local _, hrp = waitForCharacter()
    if not hrp then
        log("HRP no encontrado", "error")
        return
    end

    log("Ciclo iniciado | bloque: " .. tostring(_G.BlockType))

    -- 1. Base
    if not isNear(CFG.COORDS.BASE, 5) then
        teleportTo(CFG.COORDS.BASE, 3)
    end

    -- 2. Caminadora
    if not isNear(CFG.COORDS.CAMINADORA, 5) then
        teleportTo(CFG.COORDS.CAMINADORA, 3)
    end

    -- 3. StartRun → runId
    local okStart, runId = invokeWithRetry(StartRun, CFG.MAX_RETRIES)
    if not okStart then
        log("Falló StartRun", "error")
        task.wait(2)
        return
    end
    log("StartRun OK | runId: " .. tostring(runId))

    -- 4. StartMove (con runId si existe)
    local okMove
    if runId then
        okMove = invokeWithRetry(StartMove, CFG.MAX_RETRIES, runId)
    else
        okMove = invokeWithRetry(StartMove, CFG.MAX_RETRIES)
    end
    if not okMove then
        log("Falló StartMove", "error")
        task.wait(2)
        return
    end

    -- 5. OpenLuckyBlock (tipo + runId)
    local blockType = _G.AutoZeus and "ZEUS" or (_G.BlockType or "base14")
    local okBlock
    if runId then
        okBlock = invokeWithRetry(OpenLuckyBlock, CFG.MAX_RETRIES, blockType, runId)
    else
        okBlock = invokeWithRetry(OpenLuckyBlock, CFG.MAX_RETRIES, blockType)
    end
    if not okBlock then
        log("Falló OpenLuckyBlock (" .. blockType .. ")", "error")
        task.wait(2)
        return
    end
    log("OpenLuckyBlock OK (" .. blockType .. ")")

    -- 6. UpdateCFrame (posición + runId)
    if hrp then
        local okCF
        if runId then
            okCF = invokeWithRetry(UpdateCFrame, CFG.MAX_RETRIES, hrp.CFrame, runId)
        else
            okCF = invokeWithRetry(UpdateCFrame, CFG.MAX_RETRIES, hrp.CFrame)
        end
        if not okCF then
            log("Falló UpdateCFrame (no crítico)", "warn")
        end
    end

    -- Espera al servidor
    task.wait(CFG.DELAYS.SERVER_FINISH)

    -- 7. Regresar a Base
    if not isNear(CFG.COORDS.BASE, 5) then
        teleportTo(CFG.COORDS.BASE, 3)
    end

    task.wait(CFG.DELAYS.CYCLE_END)
    log("Ciclo completado")
end

