local lbRunning = false
local function lbFarmCycle()
    local _, hrp = waitForCharacter()

    teleportTo(LB_CONFIG.COORDS.CAMINADORA, "Caminadora")
    task.wait(LB_CONFIG.DELAYS.BETWEEN_STEPS)

    safeInvoke(StartRun)
    task.wait(LB_CONFIG.DELAYS.AFTER_ACTION)
    task.wait(LB_CONFIG.DELAYS.BETWEEN_STEPS)

    safeInvoke(EndMove)
    task.wait(LB_CONFIG.DELAYS.AFTER_ACTION)
    task.wait(LB_CONFIG.DELAYS.BETWEEN_STEPS)

    safeInvoke(OpenLuckyBlock, "base14")
    task.wait(LB_CONFIG.DELAYS.AFTER_OPEN_BLOCK)
    task.wait(LB_CONFIG.DELAYS.BETWEEN_STEPS)

    local blockId = getLuckyBlockId()
    safeInvoke(Collected, blockId)
    task.wait(LB_CONFIG.DELAYS.AFTER_ACTION)
    task.wait(LB_CONFIG.DELAYS.BETWEEN_STEPS)

    safeInvoke(UpdateCFrame, hrp.CFrame)
    task.wait(LB_CONFIG.DELAYS.AFTER_ACTION)
    task.wait(LB_CONFIG.DELAYS.BETWEEN_STEPS)

    teleportTo(LB_CONFIG.COORDS.BASE, "Base")
    task.wait(LB_CONFIG.DELAYS.CYCLE_END)
end

local function startLbFarmLoop()
    if lbRunning then return end
    lbRunning = true
    task.spawn(function()
        while _G.AutoLBFarm do
            local ok, err = pcall(lbFarmCycle)
            if not ok then
                warn("[LB Farm] Error: " .. tostring(err))
                task.wait(2)
            end
        end
        lbRunning = false
    end)
end

