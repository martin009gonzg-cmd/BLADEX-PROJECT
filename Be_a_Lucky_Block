local ablToggle = autoSection:AddToggle({
    Name = "Auto Buy Best Luckyblock", Default = false,
    Callback = function(state)
        runningABL = state
        if state then
            task.spawn(function()
                local buy = findRemote("SkinService", "BuySkin")
                while runningABL do
                    local gui = LP.PlayerGui:FindFirstChild("Windows")
                    if gui then
                        local pickaxeShop = gui:FindFirstChild("PickaxeShop")
                        if pickaxeShop then
                            local scrollingFrame = pickaxeShop:FindFirstChild("ShopContainer") and
                                pickaxeShop.ShopContainer:FindFirstChild("ScrollingFrame")
                            if scrollingFrame then
                                local cash = LP.leaderstats.Cash.Value
                                local bestSkin, bestPrice = nil, 0
                                for _, name in ipairs(skins) do
                                    local item = scrollingFrame:FindFirstChild(name)
                                    if item then
                                        local buyButton = item:FindFirstChild("Main") and
                                            item.Main:FindFirstChild("Buy") and
                                            item.Main.Buy:FindFirstChild("BuyButton")
                                        if buyButton and buyButton.Visible then
                                            local cashLabel = buyButton:FindFirstChild("Cash")
                                            if cashLabel then
                                                local price = parseCash(cashLabel.Text)
                                                if cash >= price and price > bestPrice then
                                                    bestSkin = name bestPrice = price
                                                end
                                            end
                                        end
                                    end
                                end
                                if bestSkin and buy then pcall(function() buy:InvokeServer(bestSkin) end) end
                            end
                        end
                    end
                    task.wait(0.5)
                end
            end)
        end
    end
})

