-- ==================== TOGGLE HELPER ====================
local LOOP_MAP = {
    AutoContainer = loopAutoContainer, AutoLBFarm = loopAutoLBFarm,
    AutoSell = loopAutoSell, AutoRebirth = loopAutoRebirth, AutoPlaceBest = loopAutoPlaceBest,
}

local function toggle(name, val)
    _G[name] = val
    if val then
        if name == "AutoUpgrades" then startUpgradeLoop()
        elseif name == "AutoSpeed" then startSpeedLoop()
        elseif LOOP_MAP[name] then setLoop(name, val, LOOP_MAP[name]) end
    else
        if name == "AutoUpgrades" then if upgradeLoopThread then pcall(task.cancel, upgradeLoopThread) upgradeLoopThread = nil end
        elseif name == "AutoSpeed" then speedRunning = false
        else stopLoop(name) end
    end
end

-- Monitor de cambios
task.spawn(function()
    local lastState = {}
    while true do
        for name, fn in pairs(LOOP_MAP) do
            local current = _G[name]
            if current ~= lastState[name] then
                if current then startLoop(name, fn) else stopLoop(name) end
                lastState[name] = current
            end
        end
        task.wait(0.5)
    end
end)

