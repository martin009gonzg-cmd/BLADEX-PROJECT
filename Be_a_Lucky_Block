task.spawn(function()
    local lastState = {}
    while true do
        -- [Aquí van los condicionales de los demás loops]

        -- LB Farm: solo iniciar si cambió a true; resetear lbRunning si cambió a false
        if _G.AutoLBFarm and not lastState.AutoLBFarm then
            startLbFarmLoop()
        elseif not _G.AutoLBFarm then
            lbRunning = false  -- FIX: siempre resetear, no solo al cambio
        end

        lastState.AutoLBFarm = _G.AutoLBFarm
        task.wait(1)
    end
end)

