-- Mapa de loops (incluye el nuevo AutoLBFarm)
local LOOP_MAP = {
    AutoUpgrades = startUpgradeLoop,
    AutoContainer = loopAutoContainer,
    AutoSell = loopAutoSell,
    AutoRebirth = loopAutoRebirth,
    AutoSpeed = startSpeedLoop,
    AutoLBFarm = loopAutoLBFarm,
}

local activeThreads = {}

local function startLoop(name, fn)
    if activeThreads[name] then
        pcall(task.cancel, activeThreads[name])
        activeThreads[name] = nil
    end
    activeThreads[name] = task.spawn(fn)
end

local function stopLoop(name)
    if activeThreads[name] then
        pcall(task.cancel, activeThreads[name])
        activeThreads[name] = nil
    end
end

local function setLoop(name, enabled, fn)
    if enabled then
        startLoop(name, fn)
    else
        stopLoop(name)
    end
end

local function toggle(name, val)
    _G[name] = val
    if val then
        if name == "AutoUpgrades" then
            startUpgradeLoop()
        elseif name == "AutoSpeed" then
            startSpeedLoop()
        elseif LOOP_MAP[name] then
            setLoop(name, val, LOOP_MAP[name])
        end
    else
        if name == "AutoUpgrades" then
            if upgradeLoopThread then
                pcall(task.cancel, upgradeLoopThread)
                upgradeLoopThread = nil
            end
        elseif name == "AutoSpeed" then
            speedRunning = false
        else
            stopLoop(name)
        end
    end
end

-- Monitor de cambios para los loops
task.spawn(function()
    local lastState = {}
    while true do
        for name, fn in pairs(LOOP_MAP) do
            local current = _G[name]
            if current ~= lastState[name] then
                if current then
                    if name == "AutoUpgrades" then
                        startUpgradeLoop()
                    elseif name == "AutoSpeed" then
                        startSpeedLoop()
                    else
                        startLoop(name, fn)
                    end
                else
                    if name == "AutoUpgrades" then
                        if upgradeLoopThread then
                            pcall(task.cancel, upgradeLoopThread)
                            upgradeLoopThread = nil
                        end
                    elseif name == "AutoSpeed" then
                        speedRunning = false
                    else
                        stopLoop(name)
                    end
                end
                lastState[name] = current
            end
        end
        task.wait(0.5)
    end
end)

