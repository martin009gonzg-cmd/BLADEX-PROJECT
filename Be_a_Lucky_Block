-- Retorna true si el personaje está vivo
local function isAlive()
    local char = LP.Character
    if not char then return false end
    local hum = char:FindFirstChild("Humanoid")
    return hum ~= nil and hum.Health > 0
end

-- Invoke seguro sin reintentos (uso interno)
local function safeInvoke(remote, ...)
    if not remote then return false, "Remoto no disponible" end
    local ok, res = pcall(remote.InvokeServer, remote, ...)
    return ok, res
end

-- Teleport con verificación de llegada y check de vida
local function teleportTo(cf, label)
    label = label or "destino"
    for attempt = 1, LB_CONFIG.MAX_RETRIES do
        if not isAlive() then
            warn("[Teleport] Personaje muerto, abortando teleport a " .. label)
            return false
        end
        local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            hrp.CFrame = cf
            task.wait(LB_CONFIG.DELAYS.AFTER_TELEPORT)
            if (hrp.CFrame.Position - cf.Position).Magnitude < 5 then
                return true
            end
        end
        warn("[Teleport] Intento " .. attempt .. "/" .. LB_CONFIG.MAX_RETRIES .. " fallido hacia " .. label)
        task.wait(LB_CONFIG.RETRY_DELAY)
    end
    warn("[Teleport] No se pudo llegar a " .. label)
    return false
end

-- Teleport con espera activa de confirmación
local function teleportToWithConfirm(cf, maxWait)
    maxWait = maxWait or 3
    if not isAlive() then return false end
    local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    hrp.CFrame = cf
    local start = tick()
    while tick() - start < maxWait do
        task.wait(0.1)
        if not isAlive() then return false end
        if hrp and (hrp.Position - cf.Position).Magnitude < 5 then
            return true
        end
    end
    return false
end

-- Verifica si el personaje está cerca de un CFrame
local function isNear(cf, threshold)
    local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    return (hrp.Position - cf.Position).Magnitude < (threshold or 5)
end

-- Invoke con reintentos, verifica vida entre intentos
-- CAMBIO CLAVE: los args varargs se pasan DESPUÉS de maxRetries
local function invokeWithRetry(remote, maxRetries, ...)
    maxRetries = maxRetries or LB_CONFIG.MAX_RETRIES
    local args = {...}
    for i = 1, maxRetries do
        if not isAlive() then
            warn("[invokeWithRetry] Personaje muerto, abortando")
            return false, nil
        end
        local ok, res = pcall(remote.InvokeServer, remote, table.unpack(args))
        if ok and res ~= false then
            return true, res
        end
        warn("[Retry " .. i .. "/" .. maxRetries .. "] Falló: " .. tostring(remote) ..
             " | res=" .. tostring(res))
        task.wait(LB_CONFIG.RETRY_DELAY)
    end
    return false, nil
end

-- Espera al humanoid en un estado específico con timeout
local function waitForHumanoidState(state, timeout)
    timeout = timeout or 5
    local hum = LP.Character and LP.Character:FindFirstChild("Humanoid")
    if not hum then return false end
    local start = tick()
    while hum:GetState() ~= state and tick() - start < timeout do
        task.wait()
    end
    return hum:GetState() == state
end

-- Espera a que el personaje esté listo y vivo
local function waitForCharacter()
    local char = LP.Character or LP.CharacterAdded:Wait()
    local hum  = char:WaitForChild("Humanoid", 10)
    if hum and hum.Health <= 0 then
        char = LP.CharacterAdded:Wait()
        task.wait(LB_CONFIG.DELAYS.RESPAWN_WAIT)
    end
    -- Espera extra para que el HRP esté disponible
    local hrp = char:WaitForChild("HumanoidRootPart", 10)
    return char, hrp
end

