-- 4. FUNCIONES AUXILIARES MEJORADAS
-- ════════════════════════════════════════════════════════════════
local function safeInvoke(remote, ...)
    if not remote then return false, "Remoto no disponible" end
    local ok, res = pcall(remote.InvokeServer, remote, ...)
    return ok, res
end

local function log(msg, level)
    level = level or "info"
    if level == "error" then
        warn("[LB Farm] " .. msg)
    else
        print("[LB Farm] " .. msg)
    end
end

local function isNear(cf, threshold)
    local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    return (hrp.Position - cf.Position).Magnitude < (threshold or 5)
end

local function teleportToWithConfirm(cf, maxWait, threshold)
    maxWait = maxWait or 5
    threshold = threshold or 10
    local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    hrp.CFrame = cf
    local start = tick()
    while tick() - start < maxWait do
        task.wait(0.1)
        if hrp and (hrp.Position - cf.Position).Magnitude < threshold then
            return true
        end
    end
    return false
end

local function waitForStableCharacter()
    local char = LP.Character or LP.CharacterAdded:Wait()
    local hum = char:WaitForChild("Humanoid", 10)
    local hrp = char:WaitForChild("HumanoidRootPart", 10)
    if hum.Health <= 0 then
        char = LP.CharacterAdded:Wait()
        hum = char:WaitForChild("Humanoid")
        hrp = char:WaitForChild("HumanoidRootPart")
        task.wait(LB_CONFIG.DELAYS.RESPAWN_WAIT)
    end
    if hum:GetState() == Enum.HumanoidStateType.GetUp then
        task.wait(0.5)
    end
    return char, hrp
end

local function ensureAtTreadmill(coords)
    for _ = 1, 3 do
        if isNear(coords.CAMINADORA, 8) then return true end
        teleportToWithConfirm(coords.CAMINADORA, 2, 12)
        task.wait(0.5)
    end
    return false
end

local function invokeWithBackoff(remote, maxAttempts, ...)
    local attempt = 0
    local delay = 0.2
    while attempt < maxAttempts do
        local ok, res = pcall(remote.InvokeServer, remote, ...)
        if ok then return true, res end
        attempt = attempt + 1
        task.wait(delay)
        delay = math.min(delay * 2, 2)
    end
    return false
end

