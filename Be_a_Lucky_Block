-- 6. CONTROL DE VARIABLES GLOBALES Y MONITOREO
-- ════════════════════════════════════════════════════════════════
-- Inicializar variables globales (por defecto todas desactivadas)
_G.AutoCollect   = _G.AutoCollect   or false
_G.AutoUpgrades  = _G.AutoUpgrades  or false
_G.AutoContainer = _G.AutoContainer or false
_G.AutoRebirth   = _G.AutoRebirth   or false
_G.AutoSpeed     = _G.AutoSpeed     or false
_G.AutoPlaceBest = _G.AutoPlaceBest or false
_G.AutoSkins     = _G.AutoSkins     or false
_G.AutoLBFarm    = _G.AutoLBFarm    or false

-- Bucle que monitorea cambios en las variables y arranca/detiene loops
task.spawn(function()
    local lastState = {}
    while true do
        -- Auto dinero
        if _G.AutoCollect and not lastState.AutoCollect then startCollectLoop()
        elseif not _G.AutoCollect and lastState.AutoCollect then
            _G.AutoCashPhysical = false; collectRunning = false end

        -- Auto mejoras
        if _G.AutoUpgrades and not lastState.AutoUpgrades then startUpgradeLoop()
        elseif not _G.AutoUpgrades and lastState.AutoUpgrades then upgradeRunning = false end

        -- Auto container
        if _G.AutoContainer and not lastState.AutoContainer then startContainerLoop()
        elseif not _G.AutoContainer and lastState.AutoContainer then containerRunning = false end

        -- Auto rebirth
        if _G.AutoRebirth and not lastState.AutoRebirth then startRebirthLoop()
        elseif not _G.AutoRebirth and lastState.AutoRebirth then rebirthRunning = false end

        -- Auto velocidad
        if _G.AutoSpeed and not lastState.AutoSpeed then startSpeedLoop()
        elseif not _G.AutoSpeed and lastState.AutoSpeed then speedRunning = false end

        -- Auto colocar brainrots
        if _G.AutoPlaceBest and not lastState.AutoPlaceBest then startPlaceBestLoop()
        elseif not _G.AutoPlaceBest and lastState.AutoPlaceBest then
            getgenv().AutoBest = false; placeBestRunning = false end

        -- Auto skins
        if _G.AutoSkins and not lastState.AutoSkins then startSkinLoop()
        elseif not _G.AutoSkins and lastState.AutoSkins then skinRunning = false end

        -- Lucky Block farm
        if _G.AutoLBFarm and not lastState.AutoLBFarm then startLbFarmLoop()
        elseif not _G.AutoLBFarm and lastState.AutoLBFarm then lbRunning = false end

        -- Guardar estado actual
        lastState = {
            AutoCollect   = _G.AutoCollect,
            AutoUpgrades  = _G.AutoUpgrades,
            AutoContainer = _G.AutoContainer,
            AutoRebirth   = _G.AutoRebirth,
            AutoSpeed     = _G.AutoSpeed,
            AutoPlaceBest = _G.AutoPlaceBest,
            AutoSkins     = _G.AutoSkins,
            AutoLBFarm    = _G.AutoLBFarm,
        }
        task.wait(1)
    end
end)

-- Función para equipar una skin (opcional)
function EquipSkin(skinId)
    safeInvoke(rf.EquipSkin, skinId)
end

