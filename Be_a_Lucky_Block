- Suponiendo que Compkiller ya está cargado en getgenv().Compkiller
local Compkiller = getgenv().Compkiller
local Window = Compkiller.new({ Name = "Mi Hub", Keybind = "LeftAlt" })

-- Crear la pestaña "Auto Farm"
local autoFarmTab = Window:DrawTab({
    Name            = "Auto Farm",      -- Nombre visible
    Icon            = "rocket",         -- Icono (opcional)
    EnableScrolling = true              -- Permite scroll si hay muchas opciones
})

-- Sección izquierda (puede tener una o dos columnas)
local leftSection = autoFarmTab:DrawSection({
    Name     = "Farm Principal",
    Position = "left",        -- izquierda (también puede ser "right")
    Minimized = false         -- si quieres que empiece cerrada
})

-- Añadir un toggle
leftSection:AddToggle({
    Name     = "auto money",
    Flag     = "auto_money",
    Default  = false,
    Callback = function(value)
        -- Aquí va la lógica cuando se activa/desactiva
        print("auto money:", value)
    end
})

leftSection:AddToggle({
    Name     = "upgrade brainrots",
    Flag     = "upgrade_brainrots",
    Default  = false,
    Callback = function(v) print("upgrade brainrots:", v) end
})

leftSection:AddToggle({
    Name     = "auto comprar velocidad",
    Flag     = "auto_speed",
    Default  = false,
    Callback = function(v) print("auto comprar velocidad:", v) end
})

leftSection:AddToggle({
    Name     = "Auto Rebirth",
    Flag     = "auto_rebirth",
    Default  = false,
    Callback = function(v) print("Auto Rebirth:", v) end
})

leftSection:AddToggle({
    Name     = "Auto Lucky Block Farm",
    Flag     = "lb_farm",
    Default  = false,
    Callback = function(v) print("Auto Lucky Block Farm:", v) end
})

leftSection:AddToggle({
    Name     = "Auto comprar lucky blocks",
    Flag     = "auto_skins",
    Default  = false,
    Callback = function(v) print("Auto comprar lucky blocks:", v) end
})

-- Opcional: sección derecha para skins u otras opciones
local rightSection = autoFarmTab:DrawSection({
    Name     = "Skins",
    Position = "right",
    Minimized = false
})

rightSection:AddDropdown({
    Name    = "Seleccionar Skin",
    Flag    = "skin_select",
    Default = "default",
    Values  = { "default", "fairy_luckyblock", "freezy_luckyblock" },
    Callback = function(v) print("Skin seleccionada:", v) end
})

rightSection:AddButton({
    Name     = "Equipar Skin",
    Callback = function()
        print("Equipando skin...")
    end
})

-- Inicializar la ventana (necesario para que se muestre)
Window:DrawConfig({ Name = "Config", Icon = "folder", Config = ConfigManager }):Init()
