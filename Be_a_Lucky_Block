-- 5.7 Auto comprar skins
local SKIN_LIST = {
    "fairy_luckyblock",
    "freezy_luckyblock",
    "lava_luckyblock",
    "gliched_luckyblock",
    "void_luckyblock",
    "cyborg_luckyblock",
    "divine_luckyblock",
    "inferno_luckyblock",
}
local skinRunning = false
local function startSkinLoop()
    if skinRunning then return end
    skinRunning = true
    task.spawn(function()
        while _G.AutoSkins do
            for _, skinId in ipairs(SKIN_LIST) do
                if not _G.AutoSkins then break end
                safeInvoke(rf.Skin, skinId)
                task.wait(3)
            end
