-- ══════════════════════════════════════════════
-- LÓGICA DE TOCAR (Touch Logic)
-- ══════════════════════════════════════════════
local function performTouchFarm(enabledVar)
    for _, v in pairs(game.Workspace:GetDescendants()) do
        if not _G[enabledVar] then break end
        if v:IsA("BasePart") and v.Transparency < 1 then
            if v:FindFirstChildOfClass("BillboardGui") or v:FindFirstChildOfClass("SurfaceGui") then
                local char = LP.Character
                if char and char:FindFirstChild("HumanoidRootPart") then
                    firetouchinterest(char.HumanoidRootPart, v, 0) 
                    task.wait()
                    firetouchinterest(char.HumanoidRootPart, v, 1) 
                end
            end
        end
    end
end

