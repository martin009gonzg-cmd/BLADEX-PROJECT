--[[
    BLADEX HUB — Brainrot Auto V5 (EDITADO)
    Presiona Left Alt para abrir / cerrar
    Auto Farm eliminado → integrado en BeALuckyBlock
]]

-- ══════════════════════════════════════════════
-- SERVICIOS
-- ══════════════════════════════════════════════
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players           = game:GetService("Players")
local LP                = Players.LocalPlayer

-- ══════════════════════════════════════════════
-- REMOTOS
-- ══════════════════════════════════════════════
local knit = ReplicatedStorage.Packages._Index
    :FindFirstChild("sleitnick_knit@1.7.0").knit.Services

local rf = {
    Brainrot   = knit.ContainerService.RF.UpgradeBrainrot,
    WorkUpdate = knit.ContainerService.RE.WorkUpdate,
    Container  = knit.ContainerService.RF.BuyContainer,
    PlaceBest  = knit.ContainerService.RF.PlaceBest,
    Rebirth    = knit.RebirthService.RF.Rebirth,
    Speed      = knit.UpgradesService.RF.Upgrade,
    Skin       = knit.SkinService.RF.BuySkin,
    EquipSkin  = knit.SkinService.RF.EquipSkin,
}

-- ══════════════════════════════════════════════
-- ESTADOS
-- ══════════════════════════════════════════════
local autoCollectOn   = false
local autoUpgradesOn  = false
local autoContainerOn = false
local autoRebirthOn   = false
local autoSpeedOn     = false
local autoSkinsOn     = false

local collectLoop, upgradeLoop, containerLoop, rebirthLoop, speedLoop, skinLoop

-- ══════════════════════════════════════════════
-- LOGICAS
-- ══════════════════════════════════════════════
local function startCollectLoop()
    if collectLoop then return end
    collectLoop = task.spawn(function()
        while autoCollectOn do
            for i = 30, 1, -1 do
                if not autoCollectOn then break end
                pcall(function() rf.WorkUpdate:FireServer(tostring(i)) end)
                task.wait(0.03)
            end
            task.wait(0.3)
        end
        collectLoop = nil
    end)
end

local function startUpgradeLoop()
    if upgradeLoop then return end
    upgradeLoop = task.spawn(function()
        while autoUpgradesOn do
            for i = 30, 1, -1 do
                if not autoUpgradesOn then break end
                pcall(function() rf.Brainrot:InvokeServer(tostring(i)) end)
                task.wait(0.05)
            end
            task.wait(0.5)
        end
        upgradeLoop = nil
    end)
end

local function startContainerLoop()
    if containerLoop then return end
    containerLoop = task.spawn(function()
        while autoContainerOn do
            pcall(function() rf.Container:InvokeServer() end)
            task.wait(1)
        end
        containerLoop = nil
    end)
end

local function startRebirthLoop()
    if rebirthLoop then return end
    rebirthLoop = task.spawn(function()
        while autoRebirthOn do
            pcall(function() rf.Rebirth:InvokeServer() end)
            task.wait(5)
        end
        rebirthLoop = nil
    end)
end

local function startSpeedLoop()
    if speedLoop then return end
    speedLoop = task.spawn(function()
        while autoSpeedOn do
            pcall(function() rf.Speed:InvokeServer("MovementSpeed", 1) end)
            task.wait(2)
        end
        speedLoop = nil
    end)
end

local SKIN_LIST = {
    "fairy_luckyblock","freezy_luckyblock","lava_luckyblock",
    "gliched_luckyblock","void_luckyblock","cyborg_luckyblock",
    "divine_luckyblock","inferno_luckyblock",
}

local function startSkinLoop()
    if skinLoop then return end
    skinLoop = task.spawn(function()
        while autoSkinsOn do
            for _, skinId in ipairs(SKIN_LIST) do
                if not autoSkinsOn then break end
                pcall(function() rf.Skin:InvokeServer(skinId) end)
                task.wait(3)
            end
        end
        skinLoop = nil
    end)
end

-- ══════════════════════════════════════════════
-- UI
-- ══════════════════════════════════════════════
local Compkiller = getgenv().Compkiller
if not Compkiller then return end

local Window = Compkiller.new({
    Name = "BLADEX HUB",
    Keybind = "LeftAlt",
    Scale = UDim2.new(0, 460, 0, 320),
})

Window:DrawCategory({ Name = "Main" })

-- TAB PRINCIPAL
local LbTab = Window:DrawTab({
    Name = "BeALuckyBlock",
    Icon = "box",
    EnableScrolling = true,
})

local LbLeft = LbTab:DrawSection({
    Name = "Auto Farm + Brainrot",
    Position = "left",
    Minimized = true
})

LbLeft:AddToggle({
    Name = "Auto Recoger (30-1)",
    Callback = function(v)
        autoCollectOn = v
        if v then startCollectLoop() end
    end
})

LbLeft:AddToggle({
    Name = "Auto Mejorar",
    Callback = function(v)
        autoUpgradesOn = v
        if v then startUpgradeLoop() end
    end
})

LbLeft:AddToggle({
    Name = "Auto Mejorar Base",
    Callback = function(v)
        autoContainerOn = v
        if v then startContainerLoop() end
    end
})

LbLeft:AddToggle({
    Name = "Auto Rebirth",
    Callback = function(v)
        autoRebirthOn = v
        if v then startRebirthLoop() end
    end
})

LbLeft:AddToggle({
    Name = "Auto Velocidad",
    Callback = function(v)
        autoSpeedOn = v
        if v then startSpeedLoop() end
    end
})

LbLeft:AddToggle({
    Name = "Auto LuckyBlocks",
    Callback = function(v)
        autoSkinsOn = v
        if v then startSkinLoop() end
    end
})

LbLeft:AddButton({
    Name = "Colocar Mejor",
    Callback = function()
        rf.PlaceBest:InvokeServer()
    end
})
