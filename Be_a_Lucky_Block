-- 5. LOOPS DE AUTOMATIZACIÓN
-- ════════════════════════════════════════════════════════════════

local collectRunning = false
local function startCollectLoop()
    if collectRunning then return end
    collectRunning = true
    task.spawn(function()
        _G.AutoCashPhysical = true
        while _G.AutoCollect do
            for _, v in pairs(workspace:GetDescendants()) do
                if not _G.AutoCollect then break end
                if v:IsA("BasePart") and v.Transparency < 1 then
                    if v:FindFirstChildOfClass("BillboardGui") or v:FindFirstChildOfClass("SurfaceGui") then
                        local char = LP.Character
                        if char and char:FindFirstChild("HumanoidRootPart") then
                            firetouchinterest(char.HumanoidRootPart, v, 0)
                            task.wait()
                            firetouchinterest(char.HumanoidRootPart, v, 1)
                        end
                    end
                end
            end
            task.wait(0.1)
        end
        _G.AutoCashPhysical = false
        collectRunning = false
    end)
end

local upgradeRunning = false
local function startUpgradeLoop()
    if upgradeRunning then return end
    upgradeRunning = true
    task.spawn(function()
        while _G.AutoUpgrades do
            for i = 30, 1, -1 do
                if not _G.AutoUpgrades then break end
                task.spawn(function()
                    safeInvoke(rf.Brainrot, tostring(i))
                end)
                task.wait(0.02)
            end
            task.wait(0.3)
        end
        upgradeRunning = false
    end)
end

local containerRunning = false
local function startContainerLoop()
